<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <Configurations>Debug</Configurations>
    <OutputType>Library</OutputType>
    <RootNamespace>Starlight</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyName>SCE</AssemblyName>
    <Nullable>disable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>embedded</DebugType>
    <DocumentationFile>bin\Debug\net6.0\Starlight.xml</DocumentationFile>
    <WarningLevel>0</WarningLevel>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="*.csv" />
    <EmbeddedResource Include="Assets\**" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="start.bat" />
    <None Remove="start.sh" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="../Libs/*.dll">
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
